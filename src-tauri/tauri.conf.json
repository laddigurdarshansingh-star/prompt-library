{
    "$schema": "https://raw.githubusercontent.com/tauri-apps/tauri/dev/crates/tauri-cli/schema.json",
    "productName": "Prompt Library",
    "version": "1.0.0",
    "identifier": "com.promptlibrary.app",
    "build": {
        "frontendDist": "../renderer",
        "devUrl": "http://localhost:1420"
    },
    "app": {
        "withGlobalTauri": true,
        "windows": [
            {
                "title": "Prompt Library",
                "width": 1100,
                "height": 750,
                "minWidth": 800,
                "minHeight": 550,
                "decorations": false,
                "transparent": false,
                "center": true
            }
        ],
        "trayIcon": {
            "iconPath": "icons/icon.png",
            "iconAsTemplate": false,
            "tooltip": "Prompt Library"
        },
        "security": {
            "csp": "default-src 'self'; img-src 'self' asset: http://asset.localhost data:; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com"
        }
    },
    "bundle": {
        "active": true,
        "targets": "all",
        "icon": [
            "icons/icon.png",
            "icons/icon.ico"
        ],
        "windows": {
            "nsis": {
                "installMode": "currentUser"
            }
        }
    },
    "plugins": {
        "clipboard-manager": {
            "all": true
        },
        "dialog": {
            "all": true
        },
        "fs": {
            "scope": {
                "allow": [
                    "$APPDATA/**",
                    "$RESOURCE/**",
                    "$HOME/Desktop/**"
                ]
            }
        },
        "shell": {
            "open": true
        }
    }
}